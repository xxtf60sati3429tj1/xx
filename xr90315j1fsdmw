    local Width = Config['Width'] or 0.5
    local Height = Config['Height'] or 1.0
    
    if Width == 0.5 and Height == 1.0 then return end
    
    local function scalePart(part)
        if not part then return end
        local scale = part:FindFirstChild("Scale")
        if not scale then
            scale = Instance.new("Vector3Value")
            scale.Name = "Scale"
            scale.Parent = part
        end
        scale.Value = Vector3.new(Width, Height, Width)
    end
    
    local parts = {
        "Head", "UpperTorso", "LowerTorso", "HumanoidRootPart",
        "LeftUpperArm", "RightUpperArm", "LeftLowerArm", "RightLowerArm",
        "LeftUpperLeg", "RightUpperLeg", "LeftLowerLeg", "RightLowerLeg",
        "LeftFoot", "RightFoot", "LeftHand", "RightHand"
    }
    
    for _, name in pairs(parts) do
        local part = Character:FindFirstChild(name)
        if part then scalePart(part) end
    end
