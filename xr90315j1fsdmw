-- panic ground - forces player to nearest ground below them from any distance
local function SetupPanicGround()
    local PanicSystem = shared.Scare and shared.Scare['Panic System']
    if not PanicSystem then return end
    
    local PanicGround = PanicSystem['Panic Ground']
    if not PanicGround or not PanicGround['Enabled'] then return end
    
    local keybind = PanicGround['Keybind']
    if not keybind then return end
    
    local keyCode = Enum.KeyCode[keybind]
    if not keyCode then return end
    
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == keyCode then
            local Character = LocalPlayer.Character
            if not Character then return end
            
            local HRP = Character:FindFirstChild("HumanoidRootPart")
            if not HRP then return end
            
            local RayOrigin = HRP.Position
            local RayDirection = Vector3.new(0, -math.huge, 0)
            local RayParams = RaycastParams.new()
            RayParams.FilterType = Enum.RaycastFilterType.Exclude
            RayParams.FilterDescendantsInstances = {Character}
            RayParams.IgnoreWater = false
            
            local Hit = Workspace:Raycast(RayOrigin, RayDirection, RayParams)
            if Hit then
                local GroundPos = Vector3.new(HRP.Position.X, Hit.Position.Y + 3, HRP.Position.Z)
                HRP.CFrame = CFrame.new(GroundPos)
                HRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                HRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                
                local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                if Humanoid then
                    Humanoid.PlatformStand = true
                    task.wait(0.05)
                    Humanoid.PlatformStand = false
                end
            end
        end
    end)
end

