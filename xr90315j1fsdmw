            ["Im-Talm-Bout-Innit-OG"] = {117301403779781},
        }
        EquippedEmotes = {"Im-Talm-Bout-Innit-OG"}
    end
    
    pcall(function()
        HumanoidDescription:SetEmotes(EmoteTable)
        HumanoidDescription:SetEquippedEmotes(EquippedEmotes)
