local function GetWeaponCheckEnabled(mode)
    if mode == "Camera Aimbot" then
        return true
    end
    
    local Config = GetConfig()
    if not Config then return true end
    local WeaponCfg = Config["Weapon Checks"] or {}
    local Weapons = WeaponCfg[mode] or {}
    if not Weapons or #Weapons == 0 then
        return true
    end
    
    local Character = LocalPlayer.Character
    if not Character then return false end
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then return true end
    local WeaponName = Tool.Name
    
    for _, Weapon in pairs(Weapons) do
        if Weapon == WeaponName then
            return true
        end
    end
    return false
end

local function IsInFOV(Player, mode)
    if not Player or not Player.Character then
        return false
    end
    
    local Settings = GetConfig()
    local Cfg = Settings and Settings[mode]
    if not Cfg then return true end
    
    local fovMethod = Cfg["FOV Method"] or "2D"
    local TargetChar = Player.Character
    
    if fovMethod == "Precise" then
        return isInPreciseFOV(TargetChar)
    end
    
    local Root = TargetChar:FindFirstChild("HumanoidRootPart")
    if not Root then
        return false
    end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(Root.Position)
    if not onScreen or screenPos.Z <= 0 then
        return false
    end
    
    if fovMethod == "2D" then
        local mousePos = UserInputService:GetMouseLocation()
        local scaledFov = getScaledFOV(mode, "2D", screenPos, Root)
        if scaledFov then
            return isIn2DFOV(screenPos, mousePos, scaledFov)
        end
        return true
    elseif fovMethod == "3D" then
        local fovConfig = getFOVConfig(mode, "3D")
        if fovConfig then
            return partInFOV3D(Root, fovConfig)
        end
        return true
    end
    
    return true
end

