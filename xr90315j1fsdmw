local function SetupHops()
    local Config = shared.Sound
    if not Config then return end
    
    local HopsCfg = Config['Hops']
    if not HopsCfg or not HopsCfg['Enabled'] then return end
    
    local percent = HopsCfg['Percent'] or 355
    local jumpPower = 50 * (percent / 100)
    jumpPower = math.clamp(jumpPower, 1, 1000)
    
    local function CleanupHops()
        if state.hopsConnection then
            state.hopsConnection:Disconnect()
            state.hopsConnection = nil
        end
        if state.hopsMonitor then
            state.hopsMonitor = nil
        end
        state.hopsHumanoid = nil
    end

    local function SetupHopsForCharacter(character)
        if not character then return end
        
        CleanupHops()
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then
            humanoid = character:WaitForChild("Humanoid", 5)
            if not humanoid then return end
        end
        
        state.hopsHumanoid = humanoid
        local originalJumpPower = humanoid.JumpPower
        
        state.hopsConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode == Enum.KeyCode.Space then
                if not state.hopsHumanoid or not state.hopsHumanoid.Parent then return end
                
                state.hopsHumanoid.JumpPower = jumpPower
                
