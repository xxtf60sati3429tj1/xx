        end
    end
    
    if not CameraTarget or not state.cameraFOVActive then
        if LastFrame.CameraFOVVisible then
            CameraFOVBox.Visible = false
            Camera3DFOVPart.Transparency = 1
            LastFrame.CameraFOVVisible = false
        end
        return
    end
    
    if fovMethod == "2D" then
        Camera3DFOVPart.Transparency = 1
        
