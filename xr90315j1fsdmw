    local mouseX, mouseY = mousePos.X, mousePos.Y
    local cam = Camera
    
    local ray = cam:ViewportPointToRay(mouseX, mouseY)
    if not ray then return nil end

    local Settings = shared.Scare
    local cfg = cfgOverride
    if not cfg then
        local silentCfg = Settings and Settings['Silent Aimbot']
        if silentCfg then
            cfg = silentCfg['Point Configuration']
        end
    end
    if not cfg then return nil end

    local scale = cfg['Point Scaling'] or 9.0
    local density = math.clamp(math.floor(scale), 2, 12)

    local allParts = {}
    for _, name in pairs(PARTS) do
        local part = character:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            table.insert(allParts, part)
        end
    end

    if #allParts == 0 then return nil end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Whitelist
    rayParams.FilterDescendantsInstances = allParts
    rayParams.IgnoreWater = true
    
    local directHit = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rayParams)
    if directHit then
        return { Part = directHit.Instance, Position = directHit.Position }
    end

    local bestDist = 1e9
    local bestResult = nil
    local STEP = 1 / (density - 1)
    local STEP_OFFSETS = {}
    for j = 0, density - 1 do STEP_OFFSETS[j + 1] = j * STEP end

    for _, part in pairs(allParts) do
        local size = part.Size
        local half = size * 0.5
        local cframe = part.CFrame

        for z = 1, density do
            local clampedZ = -half.Z + STEP_OFFSETS[z] * size.Z
            for y = 1, density do
                local clampedY = -half.Y + STEP_OFFSETS[y] * size.Y
                for x = 1, density do
                    local clampedX = -half.X + STEP_OFFSETS[x] * size.X
                    local worldPos = cframe:PointToWorldSpace(Vector3.new(clampedX, clampedY, clampedZ))
                    
                    local s = cam:WorldToViewportPoint(worldPos)
                    if s.Z > 0 then
                        local dist = (s.X - mouseX) * (s.X - mouseX) + (s.Y - mouseY) * (s.Y - mouseY)
                        if dist < bestDist then
                            bestDist = dist
                            bestResult = { Part = part, Position = worldPos }
                        end
                    end
                end
            end
        end
    end
    
    if bestResult then return bestResult end

    local root = character:FindFirstChild("HumanoidRootPart")
    if root then return { Part = root, Position = root.Position } end
    
    return nil
end

local function SetupMovementModifications()
    local uis = UserInputService
    local isSpeedEnabled = false
    local defaultSpeed = 16
    local speedConnection = nil
    
    local function getCurrentMultiplier()
        local MovementSettings = shared.Scare and shared.Scare['Movement Modifications']
        if not MovementSettings then return 1 end
        
        local MovementCfg = MovementSettings['Core']
        if not MovementCfg then return 1 end
        
        local Character = LocalPlayer.Character
        if not Character then return 1 end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid then return 1 end
        
        local CurrentState = "Normal"
        
        -- only switch to low health if health is below 30%
        if Humanoid.Health / Humanoid.MaxHealth < 0.3 then
            CurrentState = "Low Health"
        end
        
        -- removed weapon-specific detection – always use "Normal" for any tool
        -- your Core table only has Normal, Shooting, Reloading, and Low Health keys
        
        local Multiplier = 1
        local StateConfig = MovementCfg[CurrentState]
        if StateConfig and StateConfig['Multiplier'] then
            Multiplier = type(StateConfig['Multiplier']) == 'table' and StateConfig['Multiplier'][1] or StateConfig['Multiplier']
        end
        
        return Multiplier
    end
    
    local function updateSpeed()
        local Character = LocalPlayer.Character
        if not Character then return end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid then return end
        
        local MovementSettings = shared.Scare and shared.Scare['Movement Modifications']
        if not MovementSettings then return end
        
        if not isSpeedEnabled or not MovementSettings['Enabled'] then
            if Humanoid.WalkSpeed ~= defaultSpeed then
                Humanoid.WalkSpeed = defaultSpeed
            end
            return
        end
        
        local Multiplier = getCurrentMultiplier()
        local NewSpeed = 16 * Multiplier
        NewSpeed = math.clamp(NewSpeed, 0, 1000)
        if Humanoid.WalkSpeed ~= NewSpeed then
            Humanoid.WalkSpeed = NewSpeed
        end
    end
    
    uis.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        local MovementSettings = shared.Scare and shared.Scare['Movement Modifications']
        if not MovementSettings then return end
        
        if not MovementSettings['Enabled'] then return end
        
        local keybind = MovementSettings['Keybind']
        if not keybind then return end
        
        local keyCode = Enum.KeyCode[keybind]
        if input.KeyCode == keyCode then
            isSpeedEnabled = not isSpeedEnabled
            
            if isSpeedEnabled then
                if not speedConnection then
                    speedConnection = RunService.RenderStepped:Connect(updateSpeed)
                end
                updateSpeed()
            else
                if speedConnection then
                    speedConnection:Disconnect()
                    speedConnection = nil
                end
                local Character = LocalPlayer.Character
                if Character then
                    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                    if Humanoid and Humanoid.WalkSpeed ~= defaultSpeed then
                        Humanoid.WalkSpeed = defaultSpeed
                    end
                end
            end
        end
    end)
    
    LocalPlayer.CharacterAdded:Connect(function(character)
        local Humanoid = character:WaitForChild("Humanoid")
        defaultSpeed = Humanoid.WalkSpeed
        task.wait(0.1)
        if isSpeedEnabled then updateSpeed() end
    end)
    
    if LocalPlayer.Character then
        local Humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then defaultSpeed = Humanoid.WalkSpeed end
    end
end

