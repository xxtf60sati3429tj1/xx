    state.emoteSpooferEnabled = true
end

local function SetupDelayModifications(Character)
    if not Character then return end
    
    local DelayCfg = shared.Sound and shared.Sound['Delay Modification']
    if not DelayCfg or not DelayCfg['Enabled'] then return end
    
    local function ApplyDelay(Tool)
        if not Tool:IsA("Tool") then return end
        for Index, Connection in pairs(getconnections(Tool.Activated)) do
            local Info = debug.getinfo(Connection.Function)
            for i = 1, Info.nups do
                local c, n = debug.getupvalue(Connection.Function, i)
                if type(c) == "number" then 
                    debug.setupvalue(Connection.Function, i, 0)
                end
            end
        end
    end
    
    for _, Tool in pairs(Character:GetChildren()) do
        if Tool:IsA("Tool") then
            ApplyDelay(Tool)
        end
    end
    
    local childAddedConn = Character.ChildAdded:Connect(function(Tool)
        if Tool:IsA("Tool") then
            ApplyDelay(Tool)
        end
    end)
    table.insert(state.delayChildConnections, childAddedConn)
end

