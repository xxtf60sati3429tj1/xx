local function GetDamageOverrideMode(Tool)
    local WeaponMods = shared.Sound and shared.Sound['Weapon Modifications']
    if not WeaponMods then return nil end
    
    local DamageCfg = WeaponMods['Damage Override']
    if not DamageCfg or not DamageCfg['Enabled'] then return nil end
    
    local Weapons = DamageCfg['Weapons']
    if not Weapons then return nil end
    
    local ToolName = Tool and Tool.Name
    if not ToolName then return nil end
    
    local Mode = Weapons[ToolName]
    if not Mode then
        local Stripped = ToolName:gsub('%[', ''):gsub('%]', '')
        Mode = Weapons['[' .. Stripped .. ']'] or Weapons['[Double-Barrel SG]'] or Weapons['[Revolver]']
    end
    
    if type(Mode) == 'table' then
        local Modes = { Full = 'Head', Half = 'HumanoidRootPart', Min = 'RightFoot', Normal = 'HumanoidRootPart' }
        local ModeKey = Mode['Mode'] or Mode['Damage'] or 'Full'
        return Modes[ModeKey] or 'Head'
    end
    
    return nil
end

local function ResolveDamageOverride(Tool, VisualHitInstance)
    if not Tool then return VisualHitInstance end
    
    local TargetPartName = GetDamageOverrideMode(Tool)
    if not TargetPartName then return VisualHitInstance end
    
    if not VisualHitInstance then return nil end
    
    local Model = VisualHitInstance:FindFirstAncestorOfClass('Model')
    if not Model then return VisualHitInstance end
    
    local Humanoid = Model:FindFirstChildOfClass('Humanoid')
    if not Humanoid then return VisualHitInstance end
    
    local TargetPart = Model:FindFirstChild(TargetPartName) or Model:FindFirstChild('HumanoidRootPart')
    return TargetPart or VisualHitInstance
end

local function SetupDoubleTap()
    local Config = shared.Sound
    if not Config then return end
    
    local DoubleTapCfg = Config['Double Tap']
    if not DoubleTapCfg or not DoubleTapCfg['Enabled'] then return end
    
    local DoubleTapWeapons = DoubleTapCfg['Weapons'] or {}
    if #DoubleTapWeapons == 0 then return end
    
    local function GetWeaponCooldown(Tool)
        local CD = Tool:FindFirstChild('ShootingCooldown')
        if CD then return CD.Value end
        local DelayCfg = shared.Sound and shared.Sound['Delay Modification']
        if DelayCfg and DelayCfg['Enabled'] then
            local Weapons = DelayCfg['Weapons'] or {}
            local ToolName = Tool.Name
            local Delay = Weapons[ToolName] or Weapons['[Double-Barrel SG]'] or 100
            return Delay / 1000
        end
        return 0.3
    end
    
    local function GetDamageOverrideTarget(Weapon, CurrentHit)
        local WeaponMods = shared.Sound and shared.Sound['Weapon Modifications']
        if not WeaponMods then return CurrentHit end
        
        local DamageCfg = WeaponMods['Damage Override']
        if not DamageCfg or not DamageCfg['Enabled'] then return CurrentHit end
        
        local Weapons = DamageCfg['Weapons'] or {}
        local ToolName = Weapon and Weapon.Name
        if not ToolName then return CurrentHit end
        
        local Mode = Weapons[ToolName]
        if not Mode then
            local Stripped = ToolName:gsub('%[', ''):gsub('%]', '')
            Mode = Weapons['[' .. Stripped .. ']']
        end
        
        if type(Mode) == 'table' then
            local ModeKey = Mode['Mode'] or Mode['Damage'] or 'Full'
            local PartMap = {
                Full = 'Head',
                Half = 'HumanoidRootPart',
                Min = 'RightFoot',
                Normal = 'HumanoidRootPart',
            }
            local TargetPartName = PartMap[ModeKey] or 'Head'
            
            if CurrentHit and CurrentHit.Parent then
                local Model = CurrentHit:FindFirstAncestorOfClass('Model')
                if Model then
                    local TargetPart = Model:FindFirstChild(TargetPartName) or Model:FindFirstChild('HumanoidRootPart')
                    return TargetPart or CurrentHit
                end
            end
        end
        
        return CurrentHit
    end
    
    local function HookGunDoubleTap(Character)
        if not Character then return end
        
        local function ProcessTool(Tool)
            if not Tool:IsA("Tool") then return end
            
            local ToolName = Tool.Name
            local IsDoubleTapWeapon = false
            for _, WeaponName in pairs(DoubleTapWeapons) do
                if ToolName == WeaponName then
                    IsDoubleTapWeapon = true
                    break
                end
            end
            if not IsDoubleTapWeapon then return end
            
            if Tool:GetAttribute("SoundDoubleTap") then return end
            Tool:SetAttribute("SoundDoubleTap", true)
            
            local LastFire = 0
            local Cooldown = GetWeaponCooldown(Tool)
            local DoubleTapDelay = 0.065
            local IsShotgun = ToolName == '[Double-Barrel SG]' or ToolName == '[TacticalShotgun]'
            
            local function FireWeapon()
                if not Tool or not Tool.Parent then return end
                
                local Success = false
                pcall(function()
                    if Tool.Activate then
                        Tool:Activate()
                        Success = true
                    end
                end)
                if not Success then
                    pcall(function()
                        local RemoteEvent = Tool:FindFirstChild("RemoteEvent")
                        if RemoteEvent and RemoteEvent:IsA("RemoteEvent") then
                            RemoteEvent:FireServer("Shoot")
                            Success = true
                        end
                    end)
                end
                if not Success then
                    pcall(function()
                        local Fire = Tool:FindFirstChild("Fire")
                        if Fire and Fire:IsA("RemoteEvent") then
                            Fire:FireServer()
                            Success = true
                        end
                    end)
                end
                if not Success then
                    pcall(function()
                        local Shoot = Tool:FindFirstChild("Shoot")
                        if Shoot and Shoot:IsA("RemoteEvent") then
                            Shoot:FireServer()
                            Success = true
                        end
                    end)
                end
                return Success
            end
            
            local function GetFuturePrediction(Tool)
                local FutureCfg = shared.Sound and shared.Sound['Future']
                if not FutureCfg or not FutureCfg['Enabled'] then return nil end
                local Weapons = FutureCfg['Weapons'] or {}
                for WeaponName, Values in pairs(Weapons) do
                    if ToolName == WeaponName then
                        return {
                            X = Values['X'] or 0.15,
                            Y = Values['Y'] or 0.03,
                            Z = Values['Z'] or 0.14,
                        }
                    end
                end
                return nil
            end
            
            local function ApplyDamageOverride(Weapon, HitInstance)
                local WeaponMods = shared.Sound and shared.Sound['Weapon Modifications']
                if not WeaponMods then return HitInstance end
                local DamageCfg = WeaponMods['Damage Override']
                if not DamageCfg or not DamageCfg['Enabled'] then return HitInstance end
                
                local Weapons = DamageCfg['Weapons'] or {}
                local Name = Weapon and Weapon.Name
                if not Name then return HitInstance end
                
                local Mode = Weapons[Name]
                if not Mode then
                    local Stripped = Name:gsub('%[', ''):gsub('%]', '')
                    Mode = Weapons['[' .. Stripped .. ']']
                end
                
                if type(Mode) == 'table' then
                    local ModeKey = Mode['Mode'] or Mode['Damage'] or 'Full'
                    local PartMap = {
                        Full = 'Head',
                        Half = 'HumanoidRootPart',
                        Min = 'RightFoot',
                        Normal = 'HumanoidRootPart',
                    }
                    local TargetPartName = PartMap[ModeKey] or 'Head'
                    
                    if HitInstance and HitInstance.Parent then
                        local Model = HitInstance:FindFirstAncestorOfClass('Model')
                        if Model then
                            local TargetPart = Model:FindFirstChild(TargetPartName) or Model:FindFirstChild('HumanoidRootPart')
                            return TargetPart or HitInstance
                        end
                    end
                end
                return HitInstance
            end
            
            local function GetMuzzlePosition(Tool)
                local Handle = Tool:FindFirstChild('Handle')
                if not Handle then return nil end
                local MuzzleOffsets = {
                    ['[Revolver]'] = CFrame.new(0, 0.4, 1.8),
                    ['[Double-Barrel SG]'] = CFrame.new(0, 0.35, 2.2),
                    ['[TacticalShotgun]'] = CFrame.new(0, 0.25, 2.5),
                }
                local WeaponName = Tool.Name
                local Offset = MuzzleOffsets[WeaponName] or CFrame.new(0, 0.4, 1.8)
                local Muzzle = Handle:FindFirstChild('Muzzle')
                if Muzzle then return Muzzle.WorldPosition end
                return (Handle.CFrame * Offset).Position
            end
            
            local function ComputeShot(Origin, Direction, Range)
                local Params = RaycastParams.new()
                Params.FilterType = Enum.RaycastFilterType.Exclude
                Params.FilterDescendantsInstances = {LocalPlayer.Character}
                Params.IgnoreWater = true
                local Result = Workspace:Raycast(Origin, Direction * Range, Params)
                if Result then
                    return Result.Instance, Result.Position, Result.Normal
                end
                return nil, Origin + Direction * Range, nil
            end
            
            local DoubleTapConnection = Tool.Activated:Connect(function()
                local CurrentTime = tick()
                if CurrentTime - LastFire < Cooldown + 0.01 then return end
                LastFire = CurrentTime
                
                local Character = LocalPlayer.Character
                if not Character then return end
                
                local Ammo = Tool:FindFirstChild("Ammo")
                if not Ammo or Ammo.Value <= 0 then return end
                
                local Range = Tool:FindFirstChild("Range")
                local RangeValue = Range and Range.Value or 200
                
                local MuzzlePos = GetMuzzlePosition(Tool)
                if not MuzzlePos then return end
                
                local MousePos = UserInputService:GetMouseLocation()
                local Ray = Camera:ViewportPointToRay(MousePos.X, MousePos.Y)
                local Direction = Ray.Direction.Unit
                
                if IsShotgun then
                    for Tap = 1, 2 do
                        for Pellet = 1, 5 do
                            local SpreadX = (math.random() - 0.5) * 0.08
                            local SpreadY = (math.random() - 0.5) * 0.08
                            local SpreadZ = (math.random() - 0.5) * 0.08
                            local SpreadDir = Direction + Vector3.new(SpreadX, SpreadY, SpreadZ)
                            local HitInstance, HitPos = ComputeShot(MuzzlePos, SpreadDir, RangeValue)
                            
                            if Tap == 2 and HitInstance then
                                local OverrideHit = ApplyDamageOverride(Tool, HitInstance)
                                if OverrideHit ~= HitInstance then
                                    pcall(function()
                                        local Handle = Tool:FindFirstChild('Handle')
                                        if Handle then
                                            local RemoteEvent = Tool:FindFirstChild("RemoteEvent")
                                            if RemoteEvent then
                                                RemoteEvent:FireServer("Shoot", Handle, MuzzlePos, OverrideHit.Position, OverrideHit, HitPos)
    end
    return
end
                                    end)
                                end
                            end
                        end
                        if Tap == 1 then
                            task.wait(DoubleTapDelay)
                        end
                        FireWeapon()
                    end
                else
                    local FuturePred = GetFuturePrediction(Tool)
                    local Handle = Tool:FindFirstChild('Handle')
                    
                    FireWeapon()
                    task.wait(DoubleTapDelay)
                    
                    if FuturePred and Handle then
                        local OriginalCF = Handle.CFrame
                        Handle.CFrame = Handle.CFrame * CFrame.new(FuturePred.X or 0, FuturePred.Y or 0, FuturePred.Z or 0)
                        
                        local HitInstance, HitPos = ComputeShot(MuzzlePos, Direction, RangeValue)
                        local OverrideHit = ApplyDamageOverride(Tool, HitInstance)
                        
                        FireWeapon()
                        Handle.CFrame = OriginalCF
                    else
                        local HitInstance, HitPos = ComputeShot(MuzzlePos, Direction, RangeValue)
                        local OverrideHit = ApplyDamageOverride(Tool, HitInstance)
                        
                        if OverrideHit and OverrideHit ~= HitInstance then
                            pcall(function()
                                local RemoteEvent = Tool:FindFirstChild("RemoteEvent")
                                if RemoteEvent then
                                    RemoteEvent:FireServer("Shoot", Handle, MuzzlePos, OverrideHit.Position, OverrideHit, HitPos)
                                end
                            end)
                        end
                        FireWeapon()
                    end
                end
            end)
            
            table.insert(state.doubleTapConnections, DoubleTapConnection)
            
            Tool.AncestryChanged:Connect(function()
                if not Tool.Parent or not Tool.Parent:IsA("Model") then
                    for i, conn in pairs(state.doubleTapConnections) do
                        if conn == DoubleTapConnection then
                            pcall(function() conn:Disconnect() end)
                            state.doubleTapConnections[i] = nil
                            break
                        end
                    end
                end
            end)
        end
        
        local function ScanTools()
            for _, Child in pairs(Character:GetChildren()) do
                if Child:IsA("Tool") then
                    ProcessTool(Child)
                end
            end
        end
        
        ScanTools()
        
        Character.ChildAdded:Connect(function(Child)
            if Child:IsA("Tool") then
                ProcessTool(Child)
            end
        end)
    end
    
    if LocalPlayer.Character then
        HookGunDoubleTap(LocalPlayer.Character)
    end
    state.doubleTapCharacterConnection = LocalPlayer.CharacterAdded:Connect(HookGunDoubleTap)
end

SetupDoubleTap()

