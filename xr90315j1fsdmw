local function CheckConditions(Player, SkipVisibility, mode)
    local Config = GetConfig()
    if not Config then return true end
    
    local Conditions = Config['Condition Checks']
    if not Conditions then return true end
    
    local ModeConditions = Conditions[mode]
    if not ModeConditions then return true end
    
    if IsTargetDead(Player) then
        return false
    end
    
    if IsPlayerKnocked(Player) then
        return false
    end
    
    if ModeConditions['Crew'] == true and IsSameCrew(Player) then
        return false
    end
    if ModeConditions['Grabbed'] == true and IsGrabbed(Player) then
        return false
    end
    if ModeConditions['Knocked'] == true and IsPlayerKnocked(Player) then
        return false
    end
    if ModeConditions['Self-Knocked'] == true and IsLocalPlayerKnocked() then
        return false
    end
    if ModeConditions['ForceField'] == true and HasForcefieldOrInvis(Player) then
        return false
    end
    if ModeConditions['Vehicle'] == true and IsInVehicle(Player) then
        return false
    end
    if not SkipVisibility and ModeConditions['Visible'] == true then
        local Head = Player.Character:FindFirstChild("Head")
        if Head and not IsTargetVisible(Head) then
            return false
        end
    end
    
    return true
end

local function CheckConditionsExceptVisible(Player, mode)
    local Config = GetConfig()
    if not Config then return true end
    
    local Conditions = Config['Condition Checks']
    if not Conditions then return true end
    
    local ModeConditions = Conditions[mode]
    if not ModeConditions then return true end
    
    if IsTargetDead(Player) then
        return false
    end
    
    if IsPlayerKnocked(Player) then
        return false
    end
    
    if ModeConditions['Crew'] == true and IsSameCrew(Player) then
        return false
    end
    if ModeConditions['Grabbed'] == true and IsGrabbed(Player) then
        return false
    end
    if ModeConditions['Knocked'] == true and IsPlayerKnocked(Player) then
        return false
    end
    if ModeConditions['Self-Knocked'] == true and IsLocalPlayerKnocked() then
        return false
    end
    if ModeConditions['ForceField'] == true and HasForcefieldOrInvis(Player) then
        return false
    end
    if ModeConditions['Vehicle'] == true and IsInVehicle(Player) then
        return false
    end
    
    return true
end

local function IsPlayerValid(Player, mode)
    if not Player or Player == LocalPlayer then
        return false
    end
    if not Player.Character then
        return false
    end
    local Humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then
        return false
    end
    if not Player.Character:FindFirstChild("Head") then
        return false
    end
    return CheckConditions(Player, false, mode)
end

