    local Config = AvatarCfg['Configuration']
    if not Config then return end
    
    local Width = Config['Width'] or 0.5
    local Height = Config['Height'] or 1.0
    
    if Width == 0.5 and Height == 1.0 then return end
    
    local function scalePart(part)
        if not part then return end
        local scale = part:FindFirstChild("Scale")
        if not scale then
