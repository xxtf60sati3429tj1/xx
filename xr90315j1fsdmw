-- inventory sorter
local function SetupInventorySorter()
    local Config = shared.Scare
    if not Config then return end
    
    local SorterCfg = Config["Inventory Sorter"]
    if not SorterCfg or not SorterCfg["Enabled"] then return end
    
    local keybind = SorterCfg["Keybind"]
    if not keybind then return end
    
    local function CleanupSorter()
        state.sorterActive = false
    end
    
    local function SortInventory()
        if state.sorterActive then return end
        state.sorterActive = true
        
        RunService.RenderStepped:Wait()
        local temp = {}
        
        if not LocalPlayer.Backpack then
            state.sorterActive = false
            return
        end
        
        for i = 1, #LocalPlayer.Backpack:GetChildren() do
            local tool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
            if tool then
                table.insert(temp, tool)
                tool.Parent = game
            end
        end
        
        local Slots = SorterCfg["Weapons"]
        
        for slotIndex, slotName in pairs(Slots) do
            for i = 1, #temp do
                if temp[i] and temp[i].Name == slotName then
                    temp[i].Parent = LocalPlayer.Backpack
                    task.wait(0.105)
                    break
                end
            end
        end
        
        for i = 1, #temp do
            if temp[i] and temp[i].Parent ~= LocalPlayer.Backpack then
                local found = false
                for _, slot in pairs(Slots) do
                    if temp[i].Name == slot then
                        found = true
                        break
                    end
                end
                if not found then
                    pcall(function()
                        temp[i]:Destroy()
                    end)
                    task.wait()
                end
            end
        end
        
        state.sorterActive = false
    end
    
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not SorterCfg["Enabled"] then return end
        if input.KeyCode == Enum.KeyCode[keybind] then
            task.spawn(SortInventory)
        end
    end)
end

