local function basicpoint(part, rayOrigin, rayDirection)
    if not part then return nil end
    
    local check = RaycastParams.new()
    check.FilterType = Enum.RaycastFilterType.Whitelist
    check.FilterDescendantsInstances = {part}
    check.IgnoreWater = true
    
    local ray = Workspace:Raycast(rayOrigin, rayDirection * 1000, check)
    if ray and ray.Instance == part then
        return ray.Position
    end
    
    return nil
end

local function getClosestPoint(character, cfgOverride)
    if not (character and character.Parent) then 
        return nil
    end
    
    local mousePos = UserInputService:GetMouseLocation()
    local mouseX, mouseY = mousePos.X, mousePos.Y
    local cam = Camera
    
    local ray = cam:ViewportPointToRay(mouseX, mouseY)
    if not ray then
        return nil
    end

    local Settings = GetConfig()
    local cfg = cfgOverride
    if not cfg then
        local silentCfg = Settings and Settings['Silent Aimbot']
        if silentCfg then
            cfg = silentCfg['Point Configuration']
        end
    end
    if not cfg then
        return nil
    end

    local mode = cfg['Method'] or "Advanced"
    local scale = cfg['Point Scaling'] or 9.0
    local density = math.clamp(math.floor(scale), 2, 12)

    local allParts = {}
    for _, name in pairs(PARTS) do
        local part = character:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            table.insert(allParts, part)
        end
    end

    if #allParts == 0 then
        return nil
    end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Whitelist
    rayParams.FilterDescendantsInstances = allParts
    rayParams.IgnoreWater = true
    
    local directHit = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rayParams)
    if directHit then
        return { 
            Part = directHit.Instance, 
            Position = directHit.Position 
        }
    end

    if mode == "Basic" then
        local bestDist = 1e9
        local bestResult = nil
        
        for _, part in pairs(allParts) do
            local hitPoint = basicpoint(part, ray.Origin, ray.Direction)
            if hitPoint then
                local s = cam:WorldToViewportPoint(hitPoint)
                if s.Z > 0 then
                    local dist = (s.X - mouseX) * (s.X - mouseX) + (s.Y - mouseY) * (s.Y - mouseY)
                    if dist < bestDist then
                        bestDist = dist
                        bestResult = { Part = part, Position = hitPoint }
                    end
                end
            end
        end
        
        if bestResult then return bestResult end
    else
        local bestDist = 1e9
        local bestResult = nil
        
        local STEP = 1 / (density - 1)
        local STEP_OFFSETS = {}
        for j = 0, density - 1 do 
            STEP_OFFSETS[j + 1] = j * STEP 
        end

        for _, part in pairs(allParts) do
            local size = part.Size
            local half = size * 0.5
            local cframe = part.CFrame

            for z = 1, density do
                local clampedZ = -half.Z + STEP_OFFSETS[z] * size.Z
                
                for y = 1, density do
                    local clampedY = -half.Y + STEP_OFFSETS[y] * size.Y
                    
                    for x = 1, density do
                        local clampedX = -half.X + STEP_OFFSETS[x] * size.X
                        
                        local worldPos = cframe:PointToWorldSpace(Vector3.new(clampedX, clampedY, clampedZ))
                        
                        local s = cam:WorldToViewportPoint(worldPos)
                        if s.Z > 0 then
                            local dist = (s.X - mouseX) * (s.X - mouseX) + (s.Y - mouseY) * (s.Y - mouseY)
                            if dist < bestDist then
                                bestDist = dist
                                bestResult = { Part = part, Position = worldPos }
                            end
                        end
                    end
                end
            end
        end
        
        if bestResult then return bestResult end
    end

    local root = character:FindFirstChild("HumanoidRootPart")
    if root then
        return { Part = root, Position = root.Position }
    end
    
    return nil
end

local function SetupMovementModifications()
    local uis = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local isSpeedEnabled = false
    local defaultSpeed = 16
    local speedConnection = nil
    
    local function getCurrentMultiplier()
        local MovementSettings = shared.Scare and shared.Scare['Movement Modifications']
        if not MovementSettings then
            return 1
        end
        
        local MovementCfg = MovementSettings['Configuration']
        if not MovementCfg then
            return 1
        end
        
        local Character = LocalPlayer.Character
        if not Character then
            return 1
        end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid then
            return 1
        end
        
        local CurrentState = "Normal"
        local Tool = Character:FindFirstChildOfClass("Tool")
        
        if Tool then
            local ToolName = Tool.Name or ""
            if ToolName:lower():find("knife") or ToolName:lower():find("dagger") or ToolName:lower():find("blade") or ToolName:lower():find("sword") then
                CurrentState = "Knife"
            elseif ToolName:find("[Revolver]") then
                CurrentState = "[Revolver]"
            end
        end
        
        if Humanoid.Health / Humanoid.MaxHealth < 0.3 then
            CurrentState = "Low Health"
        end
        
        local Multiplier = 1
        local StateConfig = MovementCfg[CurrentState]
        if StateConfig and StateConfig['Multiplier'] then
            Multiplier = type(StateConfig['Multiplier']) == 'table' and StateConfig['Multiplier'][1] or StateConfig['Multiplier']
        end
        
        return Multiplier
    end
    
    local function updateSpeed()
        local Character = LocalPlayer.Character
        if not Character then
            return
        end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid then
            return
        end
        
        local MovementSettings = shared.Scare and shared.Scare['Movement Modifications']
        if not MovementSettings then
            return
        end
        
        if not isSpeedEnabled or not MovementSettings['Enabled'] then
            if Humanoid.WalkSpeed ~= defaultSpeed then
                Humanoid.WalkSpeed = defaultSpeed
            end
            return
        end
        
        local Method = MovementSettings['Method'] or "Speedwalk"
        local Multiplier = getCurrentMultiplier()
        
        if Method == "Speedwalk" then
            local NewSpeed = 16 * Multiplier
            NewSpeed = math.clamp(NewSpeed, 0, 1000)
            if Humanoid.WalkSpeed ~= NewSpeed then
                Humanoid.WalkSpeed = NewSpeed
            end
        elseif Method == "Velocity" then
            local RootPart = Character:FindFirstChild("HumanoidRootPart")
            if RootPart then
                local CurrentVel = RootPart.AssemblyLinearVelocity
                local VelMultiplier = Multiplier
                local NewVel = Vector3.new(CurrentVel.X * VelMultiplier, CurrentVel.Y, CurrentVel.Z * VelMultiplier)
                NewVel = Vector3.new(math.clamp(NewVel.X, -500, 500), NewVel.Y, math.clamp(NewVel.Z, -500, 500))
                RootPart.AssemblyLinearVelocity = NewVel
            end
        end
    end
    
    uis.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then
            return
        end
        
        local MovementSettings = shared.Scare and shared.Scare['Movement Modifications']
        if not MovementSettings then
            return
        end
        
        if not MovementSettings['Enabled'] then
            return
        end
        
        local keybind = MovementSettings['Keybind']
        if not keybind then
            return
        end
        
        local keyCode = Enum.KeyCode[keybind]
        if input.KeyCode == keyCode then
            isSpeedEnabled = not isSpeedEnabled
            
            if isSpeedEnabled then
                if not speedConnection then
                    speedConnection = RunService.RenderStepped:Connect(updateSpeed)
                end
                updateSpeed()
            else
                if speedConnection then
                    speedConnection:Disconnect()
                    speedConnection = nil
                end
                local Character = LocalPlayer.Character
                if Character then
                    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                    if Humanoid and Humanoid.WalkSpeed ~= defaultSpeed then
                        Humanoid.WalkSpeed = defaultSpeed
                    end
                end
            end
        end
    end)
    
    LocalPlayer.CharacterAdded:Connect(function(character)
        local Humanoid = character:WaitForChild("Humanoid")
        defaultSpeed = Humanoid.WalkSpeed
        task.wait(0.1)
        if isSpeedEnabled then
            updateSpeed()
        end
    end)
    
    if LocalPlayer.Character then
        local Humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            defaultSpeed = Humanoid.WalkSpeed
        end
    end
end

SetupMovementModifications()

