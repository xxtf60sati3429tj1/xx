local function UpdateShootDetection()
    if not state.shootDetectionEnabled then
        return
    end
    
    local Config = GetConfig()
    local TriggerCfg = Config and Config["Trigger Bot"]
    if not TriggerCfg or not TriggerCfg["Enabled"] then
        return
    end
    
    local SDCfg = TriggerCfg["Shoot Detection"] or {}
    local UseTrigger = SDCfg["Use Trigger"]
    
    if not UseTrigger then
        return
    end
    
    local MaxR = GetSelectingDistance("Trigger Bot")
    local Target = GetClosestPlayerToCursor(MaxR, "Trigger Bot")
    
    if Target and CheckConditions(Target, false, "Trigger Bot") then
        state.lockedTarget = Target
        State.TriggerTargetLocked = true
        State.Targets.Trigger = Target
        state.triggerLastValidTarget = nil
        state.triggerFOVActive = true
    else
        state.lockedTarget = nil
        State.TriggerTargetLocked = false
        State.Targets.Trigger = nil
        state.triggerLastValidTarget = nil
        state.triggerFOVActive = false
        TriggerFOVBox.Visible = false
        Trigger3DFOVPart.Transparency = 1
    end
end

local function GetCameraTargetPart(Player)
    local Character = Player.Character
    if not Character then
        return nil
    end
    
    local Config = GetConfig()
    if not Config then return nil end
    local CameraCfg = Config["Camera Aimbot"]
    if not CameraCfg then return nil end
    
    local TargetZone = CameraCfg["Target Zone"] or "Nearest Part"
    
    if TargetZone == "Head" then
        return Character:FindFirstChild("Head")
    elseif TargetZone == "UpperTorso" then
        return Character:FindFirstChild("UpperTorso")
    elseif TargetZone == "Nearest Part" or TargetZone == "Closest Part" then
        local MousePos = UserInputService:GetMouseLocation()
        local ClosestDist = math.huge
        local ClosestPart = nil
        
        for _, name in pairs(PARTS) do
            local Part = Character:FindFirstChild(name)
            if Part and Part:IsA("BasePart") then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
                if OnScreen and ScreenPos.Z > 0 then
                    local Dist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                    if Dist < ClosestDist then
                        ClosestDist = Dist
                        ClosestPart = Part
                    end
                end
            end
        end
        return ClosestPart or Character:FindFirstChild("HumanoidRootPart")
    end
    
    return Character:FindFirstChild("HumanoidRootPart")
end

local function UpdateCameraAimbot()
    local Config = GetConfig()
    local CameraCfg = Config and Config["Camera Aimbot"]
    if not CameraCfg or not CameraCfg["Enabled"] then
        return
    end
    
    if not State.CameraTargetLocked then
        local SelMode = GetCameraSelectionMode()
        if SelMode == "Always" then
            local MaxR = GetSelectingDistance("Camera Aimbot")
            local Target = GetClosestPlayerToCursor(MaxR, "Camera Aimbot")
            if Target and CheckConditions(Target, false, "Camera Aimbot") and IsInFOV(Target, "Camera Aimbot") then
                State.CameraTargetLocked = true
                State.Targets.Camera = Target
                state.cameraFOVActive = true
                state.cameraEasingProgress = 0
                state.cameraLastTarget = nil
                state.cameraShakeTime = 0
            end
        end
        return
    end
    
    ValidateTarget("Camera")
    
    local Target = State.Targets.Camera
    if not Target then
        return
    end
    
    if not CheckConditions(Target, false, "Camera Aimbot") then
        State.CameraTargetLocked = false
        State.Targets.Camera = nil
        state.cameraFOVActive = false
        state.cameraEasingProgress = 0
        state.cameraLastTarget = nil
        state.cameraShakeTime = 0
        CameraFOVBox.Visible = false
        Camera3DFOVPart.Transparency = 1
        return
    end
    
    local inFOV = IsInFOV(Target, "Camera Aimbot")
    if not inFOV then
        return
    end
    
    local Character = LocalPlayer.Character
    if not Character then
        return
    end
    
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then
        return
    end
    
    local TargetChar = Target.Character
    if not TargetChar then
        return
    end
    
    local TargetPos = nil
    local TargetPart = GetCameraTargetPart(Target)
    if TargetPart then
        TargetPos = TargetPart.Position
    else
        local Head = TargetChar:FindFirstChild("Head")
        if Head then
            TargetPos = Head.Position
        else
            return
        end
    end
    
    local Prediction = CameraCfg["Prediction"] or {}
    if Prediction["Enabled"] then
        local RootPart = TargetChar:FindFirstChild("HumanoidRootPart")
        if RootPart then
            local Velocity = RootPart.AssemblyLinearVelocity
            TargetPos = TargetPos + Vector3.new(
                Velocity.X * (Prediction["X"] or 0),
                Velocity.Y * (Prediction["Y"] or 0),
                Velocity.Z * (Prediction["Z"] or 0)
            )
        end
    end
    
    local AimProperties = Config["Aim Properties"] or {}
    
    local SmoothingValue = 0.34
    local Snappiness = 0.05
    local SensitivityMultiplier = 1.0
    local PullBackEnabled = true
    
    local PullBackStrength = AimProperties["Pull Back Strength"] or {}
    if PullBackStrength["Enabled"] == false then
        PullBackEnabled = false
    end
    
    local Smoothing = AimProperties["Smoothing"] or {}
    if Smoothing["Enabled"] then
        SmoothingValue = Smoothing["X Smoothing"] or 0.34
    end
    
    local RangeBasedSmoothing = AimProperties["Range Based Smoothing"] or {}
    if RangeBasedSmoothing["Enabled"] then
        local RootPart = TargetChar:FindFirstChild("HumanoidRootPart")
        if RootPart then
            local Distance = (Camera.CFrame.Position - RootPart.Position).Magnitude
            local FarRange = RangeBasedSmoothing["Far Range"] or {}
            local MediumRange = RangeBasedSmoothing["Medium Range"] or {}
            local CloseRange = RangeBasedSmoothing["Close Range"] or {}
            
            if Distance >= 80 then
                SmoothingValue = FarRange["X"] or 0.34
            elseif Distance >= 35 then
                SmoothingValue = MediumRange["X"] or 0.34
            else
                SmoothingValue = CloseRange["X"] or 0.34
            end
        end
    end
    
    local SnappinessCfg = AimProperties["Snappiness"] or {}
    if SnappinessCfg["Enabled"] then
        local SnapMethod = SnappinessCfg["Snap Method"] or "Basic"
        if SnapMethod == "Basic" then
            local BasicCfg = SnappinessCfg["Basic"] or {}
            Snappiness = BasicCfg["X"] or 0.05
        elseif SnapMethod == "Advanced" then
            local AdvancedCfg = SnappinessCfg["Advanced"] or {}
            Snappiness = AdvancedCfg["X Strength"] or 0.05
        end
    end
    
    local Sensitivity = AimProperties["Sensitivity"] or {}
    if Sensitivity["Enabled"] then
        local SensMethod = Sensitivity["Sensitivity Method"] or "Basic"
        if SensMethod == "Basic" then
            local BasicCfg = Sensitivity["Basic"] or {}
            SensitivityMultiplier = (BasicCfg["X"] or 0.091) * 10
        elseif SensMethod == "Advanced" then
            local AdvancedCfg = Sensitivity["Advanced"] or {}
            SensitivityMultiplier = (AdvancedCfg["X Strength"] or 0.24) * 10
        end
        SensitivityMultiplier = math.clamp(SensitivityMultiplier, 0.1, 10)
    end
    
    SmoothingValue = SmoothingValue * SensitivityMultiplier
    SmoothingValue = math.clamp(SmoothingValue, 0.001, 1)
    
    if Target ~= state.cameraLastTarget then
        state.cameraEasingProgress = 0
        state.cameraLastTarget = Target
    end
    
    state.cameraEasingProgress = math.min((state.cameraEasingProgress or 0) + Snappiness, 1)
    
    local ShakeOffset = Vector3.new(0, 0, 0)
    local Shake = AimProperties["Shake"] or {}
    if Shake["Enabled"] then
        local DeltaTime = 1 / 60
        state.cameraShakeTime = (state.cameraShakeTime or 0) + DeltaTime
        
        local Frequency = Shake["Frequency"] or 7
        local Intensity = Shake["Intensity"] or { X = 5, Y = 5, Z = 4 }
        local Decay = Shake["Decay"] or 55
        
        local DecayFactor = math.exp(-Decay * state.cameraShakeTime)
        local Time = state.cameraShakeTime * Frequency * math.pi * 2
        
        ShakeOffset = Vector3.new(
            math.sin(Time * 1.3) * math.cos(Time * 0.7) * (Intensity.X or 0) * DecayFactor * 0.02,
            math.cos(Time * 1.1) * math.sin(Time * 0.9) * (Intensity.Y or 0) * DecayFactor * 0.02,
            math.sin(Time * 0.8) * math.cos(Time * 1.2) * (Intensity.Z or 0) * DecayFactor * 0.02
        )
    end
    
    TargetPos = TargetPos + ShakeOffset
    
    local Humanization = AimProperties["Humanization"] or {}
    local Transitioning = Humanization["Transitioning"] or {}
    local TransitionAmountX = 0
    local TransitionAmountY = 0
    
    if Transitioning["Enabled"] then
        local TransitionCfg = Transitioning["Transition Amount"] or {}
        TransitionAmountX = TransitionCfg["X"] or 0.6872
        TransitionAmountY = TransitionCfg["Y"] or 0.7392
        
        TransitionAmountX = math.clamp(TransitionAmountX, 0, 1)
        TransitionAmountY = math.clamp(TransitionAmountY, 0, 1)
    end
    
    local AimMethod = CameraCfg["Aim Method"] or "Memory"
    local MousePos = UserInputService:GetMouseLocation()
    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(TargetPos)
    local EffectiveSmoothing = SmoothingValue * state.cameraEasingProgress
    
    if not PullBackEnabled then
        if AimMethod == "Memory" or AimMethod == "Both" then
            local Cam = Camera
            local CurrentLook = Cam.CFrame.LookVector
            local TargetLook = (TargetPos - Cam.CFrame.Position).Unit
            local AimLook = CurrentLook:Lerp(TargetLook, EffectiveSmoothing)
            Cam.CFrame = CFrame.new(Cam.CFrame.Position, Cam.CFrame.Position + AimLook)
        end
        
        if AimMethod == "Mouse" or AimMethod == "Both" then
            if OnScreen and ScreenPos.Z > 0 then
                local DeltaX = ScreenPos.X - MousePos.X
                local DeltaY = ScreenPos.Y - MousePos.Y
                local AimDeltaX = DeltaX * EffectiveSmoothing
                local AimDeltaY = DeltaY * EffectiveSmoothing
                if math.abs(AimDeltaX) > 0.3 or math.abs(AimDeltaY) > 0.3 then
                    mousemoverel(math.floor(AimDeltaX), math.floor(AimDeltaY))
                end
            end
        end
    else
        if AimMethod == "Memory" or AimMethod == "Both" then
            if Transitioning["Enabled"] then
                local Cam = Camera
                local CurrentLook = Cam.CFrame.LookVector
                local TargetLook = (TargetPos - Cam.CFrame.Position).Unit
                local AimLook = CurrentLook:Lerp(TargetLook, EffectiveSmoothing)
                local MouseDelta = UserInputService:GetMouseDelta()
                local MouseInfluenceX = math.clamp(math.abs(MouseDelta.X) * 0.01 * TransitionAmountX, 0, 1)
                local MouseInfluenceY = math.clamp(math.abs(MouseDelta.Y) * 0.01 * TransitionAmountY, 0, 1)
                local MouseInfluence = math.max(MouseInfluenceX, MouseInfluenceY)
                AimLook = AimLook:Lerp(CurrentLook, MouseInfluence)
                Cam.CFrame = CFrame.new(Cam.CFrame.Position, Cam.CFrame.Position + AimLook)
            end
        end
        
        if AimMethod == "Mouse" or AimMethod == "Both" then
            if OnScreen and ScreenPos.Z > 0 then
                local DeltaX = ScreenPos.X - MousePos.X
                local DeltaY = ScreenPos.Y - MousePos.Y
                if Transitioning["Enabled"] then
                    local MouseDelta = UserInputService:GetMouseDelta()
                    local AimDeltaX = DeltaX * EffectiveSmoothing
                    local AimDeltaY = DeltaY * EffectiveSmoothing
                    local FinalDeltaX = AimDeltaX * (1 - TransitionAmountX) + MouseDelta.X * TransitionAmountX
                    local FinalDeltaY = AimDeltaY * (1 - TransitionAmountY) + MouseDelta.Y * TransitionAmountY
                    if math.abs(FinalDeltaX) > 0.3 or math.abs(FinalDeltaY) > 0.3 then
                        mousemoverel(math.floor(FinalDeltaX), math.floor(FinalDeltaY))
                    end
                else
                    if math.abs(DeltaX) > 0.5 or math.abs(DeltaY) > 0.5 then
                        mousemoverel(math.floor(DeltaX * EffectiveSmoothing), math.floor(DeltaY * EffectiveSmoothing))
                    end
                end
            end
        end
    end
end

